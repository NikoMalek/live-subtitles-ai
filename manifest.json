{ 
  "manifest_version": 3,
  "name": "Live Subtitles AI",
  "version": "1.0",
  "description": "Offline subtitles AI for any video on the web.",

  "permissions": [ 
  "tabCapture", 
  "activeTab",
  "scripting"
  ],
  "background": { "service_worker": "background.js" },

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}